# ─────────────────────────────────────────────────────────────────────────────
# web-search-mcp-server — Environment Variables
# Copy this file to .env for local development
# ─────────────────────────────────────────────────────────────────────────────

# SerpAPI key — required for 19 of 20 tools
# Get a free key at https://serpapi.com (100 searches/month free)
SERPAPI_API_KEY=your_serpapi_key_here

# MCP Server protection key — clients must send this in every request
# Generate a strong random key, e.g.: openssl rand -hex 32
# Send as:  Authorization: Bearer <key>
#       or: x-api-key: <key>
# Leave empty to disable auth (development only)
MCP_API_KEY=your_secret_mcp_key_here

# Transport mode: "stdio" (Claude Desktop) or "http" (server/Vercel)
TRANSPORT=stdio

# HTTP port — only used when TRANSPORT=http (not needed on Vercel)
PORT=3000
